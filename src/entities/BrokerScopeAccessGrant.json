      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time",
      "nullable": true,
      "description": "null = permanent; past date = expired"
    },
    "distribution_channel_context_id": {
      "type": "string",
      "nullable": true,
      "description": "FK to DistributionChannelContext (added)"
