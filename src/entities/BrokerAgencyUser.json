{
  "name": "BrokerAgencyUser",
  "type": "object",
  "properties": {
    "tenant_id": {
      "type": "string",
      "description": "Tenant scope"
    },
    "broker_agency_id": {
      "type": "string",
      "description": "FK to BrokerAgencyProfile"
    },
    "user_email": {
      "type": "string",
      "format": "email",
      "description": "Email of the user (FK to User)"
    },
    "first_name": {
      "type": "string"
    },
    "last_name": {
      "type": "string"
    },
    "role": {
      "type": "string",
      "enum": [
        "broker_agency_admin",
        "broker_producer",
        "broker_account_manager",
        "broker_benefits_admin",
        "broker_quote_user",
        "broker_read_only"
      ],
      "default": "broker_producer"
    },
    "status": {
      "type": "string",
      "enum": [
        "invited",
        "active",
        "inactive",
        "suspended"
      ],
      "default": "invited"
    },
    "invited_at": {
      "type": "string",
      "format": "date-time"
    },
    "accepted_at": {
      "type": "string",
      "format": "date-time"
    },
    "last_login_at": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "tenant_id",
    "broker_agency_id",
    "user_email",
    "first_name",
    "last_name"
  ]
}