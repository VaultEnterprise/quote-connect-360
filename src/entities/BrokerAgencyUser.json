{
  "name": "BrokerAgencyUser",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "broker_agency_id": {
      "type": "string",
      "description": "FK to BrokerAgencyProfile (scoping field)"
    },
    "user_id": {
      "type": "string",
      "nullable": true,
      "description": "Base44 User ID (null during invitation, set after acceptance)"
    },
    "email": {
      "type": "string",
      "description": "User email (primary key for invite matching)"
    },
    "first_name": {
      "type": "string"
    },
    "last_name": {
      "type": "string"
    },
    "role": {
      "type": "string",
      "enum": ["owner", "manager", "viewer"],
      "description": "Broker-level role"
    },
    "status": {
      "type": "string",
      "enum": ["invited", "active", "suspended", "deactivated"],
      "default": "invited"
    },
    "invited_by_user_id": {
      "type": "string",
      "nullable": true
    },
    "invited_at": {
      "type": "string",
      "format": "date-time",
      "nullable": true
    },
    "accepted_at": {
      "type": "string",
      "format": "date-time",
      "nullable": true
    },
    "distribution_channel_context_id": {
      "type": "string",
      "nullable": true,
      "description": "FK to DistributionChannelContext (added)"
    },
    "master_general_agent_id": {
      "type": "string",
      "nullable": true,
      "description": "MGA scope if applicable (added)"
    },
    "owner_org_type": {
      "type": "string",
      "enum": ["platform", "broker_agency", "mga", "employer"],
      "nullable": true
    },
    "owner_org_id": {
      "type": "string",
      "nullable": true
    },
    "servicing_org_type": {
      "type": "string",
      "enum": ["broker_agency", "mga", "employer", "benefits_admin"],
      "nullable": true
    },
    "servicing_org_id": {
      "type": "string",
      "nullable": true
    },
    "supervising_org_type": {
      "type": "string",
      "enum": ["mga", "platform"],
      "nullable": true
    },
    "supervising_org_id": {
      "type": "string",
      "nullable": true
    },
    "created_by_user_id": {
      "type": "string",
      "nullable": true
    },
    "created_by_role": {
      "type": "string",
      "nullable": true
    },
    "visibility_scope": {
      "type": "string",
      "enum": ["owner_only", "owner_and_servicing", "owner_and_supervising", "owner_and_all_affiliates", "platform_wide"],
      "nullable": true
    },
    "audit_trace_id": {
      "type": "string",
      "nullable": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["tenant_id", "broker_agency_id", "email", "first_name", "last_name", "role"]
}