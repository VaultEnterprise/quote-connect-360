{
  "name": "QuoteScenario",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "distribution_channel_context_id": {
      "type": "string",
      "nullable": true
    },
    "master_general_agent_id": {
      "type": "string",
      "nullable": true,
      "description": "MGA scope (non-identifying)"
    },
    "broker_agency_id": {
      "type": "string",
      "nullable": true
    },
    "owner_org_type": {
      "type": "string",
      "enum": ["platform", "broker_agency", "mga", "employer"],
      "nullable": true
    },
    "owner_org_id": {
      "type": "string",
      "nullable": true
    },
    "servicing_org_type": {
      "type": "string",
      "enum": ["broker_agency", "mga", "employer", "benefits_admin"],
      "nullable": true
    },
    "servicing_org_id": {
      "type": "string",
      "nullable": true
    },
    "supervising_org_type": {
      "type": "string",
      "enum": ["mga", "platform"],
      "nullable": true
    },
    "supervising_org_id": {
      "type": "string",
      "nullable": true
    },
    "created_by_user_id": {
      "type": "string",
      "nullable": true
    },
    "created_by_role": {
      "type": "string",
      "nullable": true
    },
    "visibility_scope": {
      "type": "string",
      "enum": ["owner_only", "owner_and_servicing", "owner_and_supervising", "owner_and_all_affiliates", "platform_wide"],
      "nullable": true
    },
    "audit_trace_id": {
      "type": "string",
      "nullable": true
    },
    "case_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string",
      "nullable": true
    },
    "status": {
      "type": "string",
      "enum": ["draft", "running", "completed", "error", "expired"],
      "default": "draft"
    },
    "census_version_id": {
      "type": "string",
      "nullable": true
    },
    "products_included": {
      "type": "array",
      "items": {"type": "string"},
      "nullable": true
    },
    "total_monthly_premium": {
      "type": "number",
      "nullable": true
    },
    "employer_monthly_cost": {
      "type": "number",
      "nullable": true
    },
    "notes": {
      "type": "string",
      "nullable": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["tenant_id", "case_id", "name"]
}