{
  "name": "CensusVersion",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "distribution_channel_context_id": {
      "type": "string",
      "nullable": true
    },
    "master_general_agent_id": {
      "type": "string",
      "nullable": true,
      "description": "MGA scope (non-identifying)"
    },
    "broker_agency_id": {
      "type": "string",
      "nullable": true
    },
    "owner_org_type": {
      "type": "string",
      "enum": ["platform", "broker", "mga", "employer"],
      "nullable": true
    },
    "owner_org_id": {
      "type": "string",
      "nullable": true
    },
    "servicing_org_type": {
      "type": "string",
      "enum": ["broker", "mga", "employer", "benefits_admin"],
      "nullable": true
    },
    "servicing_org_id": {
      "type": "string",
      "nullable": true
    },
    "supervising_org_type": {
      "type": "string",
      "enum": ["mga", "platform"],
      "nullable": true
    },
    "supervising_org_id": {
      "type": "string",
      "nullable": true
    },
    "created_by_user_id": {
      "type": "string",
      "nullable": true
    },
    "created_by_role": {
      "type": "string",
      "nullable": true
    },
    "visibility_scope": {
      "type": "string",
      "enum": ["owner_only", "owner_and_servicing", "owner_and_supervising", "owner_and_all_affiliates", "platform_wide"],
      "nullable": true
    },
    "audit_trace_id": {
      "type": "string",
      "nullable": true
    },
    "case_id": {
      "type": "string"
    },
    "version_number": {
      "type": "number",
      "default": 1
    },
    "file_url": {
      "type": "string",
      "nullable": true
    },
    "file_name": {
      "type": "string",
      "nullable": true
    },
    "status": {
      "type": "string",
      "enum": ["uploaded", "mapping", "validating", "validated", "has_issues", "archived"],
      "default": "uploaded"
    },
    "total_employees": {
      "type": "number",
      "nullable": true
    },
    "total_dependents": {
      "type": "number",
      "nullable": true
    },
    "eligible_employees": {
      "type": "number",
      "nullable": true
    },
    "validation_errors": {
      "type": "number",
      "default": 0
    },
    "validation_warnings": {
      "type": "number",
      "default": 0
    },
    "uploaded_by": {
      "type": "string",
      "nullable": true
    },
    "validated_at": {
      "type": "string",
      "format": "date-time",
      "nullable": true
    },
    "notes": {
      "type": "string",
      "nullable": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["tenant_id", "case_id"]
}