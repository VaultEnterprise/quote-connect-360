{
  "_meta": {
    "version": "1.0",
    "description": "QC360 Import Manifest — defines all import templates, column schemas, normalization rules, and phase execution order",
    "last_updated": "2026-03-25"
  },

  "import_phases": [
    {
      "phase": "A",
      "label": "Reference Data",
      "description": "Must complete before any pricing or census imports",
      "steps": [
        { "step": 1, "import_type": "plan_master",          "target_entity": "BenefitPlan",      "source_sheet": null,              "blocking": true },
        { "step": 2, "import_type": "zip_area_map",         "target_entity": "PlanZipAreaMap",   "source_sheet": "Zip Code to Area", "blocking": true },
        { "step": 3, "import_type": "age_band_schema",      "target_entity": "AgeBandSchema",    "source_sheet": null,              "blocking": true, "note": "Seed once — use seedAgeBandSchema action" }
      ]
    },
    {
      "phase": "B",
      "label": "Plan Pricing",
      "description": "Requires Phase A to be complete and validated",
      "steps": [
        { "step": 4, "import_type": "rate_schedule_header", "target_entity": "PlanRateSchedule", "source_sheet": null,               "blocking": true },
        { "step": 5, "import_type": "rate_detail",          "target_entity": "PlanRateDetail",   "source_sheet": "Rates by Area Tier","blocking": true },
        { "step": 6, "import_type": "rate_validation",      "target_entity": null,               "source_sheet": null,               "blocking": true, "note": "Run validateRateSchedule action before promoting" }
      ]
    },
    {
      "phase": "C",
      "label": "Case Test",
      "description": "Requires Phase B complete and schedule active",
      "steps": [
        { "step": 7, "import_type": "census_members",       "target_entity": "CensusMember",     "source_sheet": "Census Input",     "blocking": false },
        { "step": 8, "import_type": "case_rating",          "target_entity": "CaseRatedResult",  "source_sheet": null,               "blocking": false, "note": "Run rateCensus action" },
        { "step": 9, "import_type": "qa_reconciliation",    "target_entity": null,               "source_sheet": "Rate Pivot Table",  "blocking": false, "note": "Compare QC360 totals to workbook pivot" }
      ]
    }
  ],

  "templates": {
    "plan_master": {
      "target_entity": "BenefitPlan",
      "required_columns": ["carrier_code","plan_code","plan_name","effective_date"],
      "optional_columns": ["market_segment","plan_year","funding_type","plan_type","rating_model","tobacco_rating_flag","termination_date","version_number"],
      "defaults": {
        "rating_model": "area_age_band_tier",
        "market_segment": "small_group",
        "funding_type": "fully_insured",
        "status": "active"
      }
    },

    "zip_area_map": {
      "target_entity": "PlanZipAreaMap",
      "source_sheet": "Zip Code to Area",
      "required_columns": ["zip_code","state_code","rating_area_code"],
      "optional_columns": ["county","city","effective_date","termination_date","plan_code"],
      "normalization": {
        "zip_code": "trim → strip non-numeric → left-pad to 5 digits → reject if not 5 digits",
        "state_code": "uppercase → trim → validate against US_STATES list",
        "rating_area_code": "trim → uppercase"
      }
    },

    "rate_schedule_header": {
      "target_entity": "PlanRateSchedule",
      "required_columns": ["plan_code","schedule_name","effective_date"],
      "optional_columns": ["schedule_code","termination_date","rating_basis","age_band_schema_code","tobacco_mode","version_number","is_active"],
      "defaults": {
        "rating_basis": "age_band_area_tier",
        "tobacco_mode": "none",
        "version_number": 1,
        "is_active": true
      }
    },

    "rate_detail": {
      "target_entity": "PlanRateDetail",
      "source_sheet": "Rates by Area Tier",
      "required_columns": ["rating_area_code","age_band_code","tier_code","monthly_rate"],
      "optional_columns": ["plan_code","schedule_code","tobacco_flag","effective_date","termination_date"],
      "normalization": {
        "tier_code": {
          "type": "lookup_map",
          "map": {
            "Single": "EE", "EE": "EE", "Employee Only": "EE", "Employee": "EE",
            "EE+Sp": "ES", "EE + Sp": "ES", "EE+Spouse": "ES", "Employee+Spouse": "ES",
            "EE+Ch": "EC", "EE+Ch(ren)": "EC", "EE + Ch(ren)": "EC", "EE+Children": "EC",
            "Family": "FAM", "FAM": "FAM", "EE+Family": "FAM", "EE + Family": "FAM"
          },
          "reject_unknown": true
        },
        "monthly_rate": "parseFloat → reject if < 0 or NaN",
        "tobacco_flag": "Y/YES/1/true → true, else false",
        "age_band_code": "validate against ACA_STANDARD_10 schema"
      }
    },

    "census_members": {
      "target_entity": "CensusMember",
      "source_sheet": "Census Input",
      "required_columns": ["zip_code","dob","tier_code"],
      "optional_columns": ["member_sequence","gender","tobacco_flag","state_code","rating_area_code","age_band_code"],
      "normalization": {
        "zip_code": "same as zip_area_map",
        "dob": "ISO date or Excel serial → ISO → reject future dates → reject null",
        "tier_code": "same as rate_detail tier map",
        "tobacco_flag": "same as rate_detail",
        "state_code": "derived from ZIP lookup if missing — do not trust sheet formula",
        "rating_area_code": "derived from ZIP lookup — do not trust sheet formula",
        "age_band_code": "derived from DOB + effective_date — do not trust sheet formula"
      },
      "do_not_trust_from_sheet": ["state_code","rating_area_code","age_band_code","age_as_of_effective"],
      "note": "All formula-derived columns in the Census Input sheet must be re-derived in QC360 backend resolvers"
    }
  },

  "unique_keys": {
    "PlanZipAreaMap":   ["plan_id", "zip_code", "effective_date"],
    "PlanRateDetail":   ["rate_schedule_id", "rating_area_code", "age_band_code", "tobacco_flag", "tier_code", "effective_date"],
    "AgeBandSchema":    ["schema_code", "band_code"],
    "CensusMember":     ["case_id", "member_sequence"]
  },

  "rollback_strategy": {
    "description": "Every ImportRun stores the run_id on each created entity row via source_row_number and import_run_id references. To roll back: delete all canonical rows where the import_run_id matches, then mark ImportRun.status = rolled_back.",
    "supported_rollback_entities": ["PlanRateDetail", "PlanZipAreaMap", "CensusMember", "CaseRatedResult"]
  }
}