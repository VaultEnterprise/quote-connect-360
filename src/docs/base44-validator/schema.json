{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://base44/enforced-remediation.schema.json",
  "type": "object",
  "required": [
    "contract_version",
    "execution_mode",
    "response_type",
    "application",
    "page_review"
  ],
  "additionalProperties": false,
  "properties": {
    "contract_version": { "type": "string", "const": "1.0.0" },
    "execution_mode": { "type": "string", "const": "strict_enforcement" },
    "response_type": { "type": "string", "const": "page_remediation_report" },
    "application": {
      "type": "object",
      "required": ["application_name", "environment", "review_scope"],
      "additionalProperties": false,
      "properties": {
        "application_name": { "type": "string", "minLength": 1 },
        "environment": { "type": "string", "minLength": 1 },
        "review_scope": { "type": "string", "const": "single_page_forensic_review" }
      }
    },
    "page_review": {
      "type": "object",
      "required": [
        "page_name",
        "page_route",
        "review_sequence",
        "review_status",
        "dependency_map",
        "failure_point_inventory",
        "issues",
        "validation",
        "console_and_server_cleanliness",
        "downstream_impact_analysis",
        "enterprise_standard_confirmation",
        "final_status"
      ],
      "additionalProperties": false,
      "properties": {
        "page_name": { "type": "string", "minLength": 1 },
        "page_route": { "type": "string", "minLength": 1 },
        "review_sequence": { "type": "integer", "minimum": 1 },
        "review_status": { "type": "string", "enum": ["complete", "partial", "failed"] },
        "dependency_map": {
          "type": "object",
          "required": ["ui_layer", "api_services", "data_layer", "auth_access", "workflow_logic", "infrastructure"],
          "additionalProperties": false,
          "properties": {
            "ui_layer": { "$ref": "#/$defs/non_empty_strings" },
            "api_services": { "$ref": "#/$defs/non_empty_strings" },
            "data_layer": { "$ref": "#/$defs/non_empty_strings" },
            "auth_access": { "$ref": "#/$defs/non_empty_strings" },
            "workflow_logic": { "$ref": "#/$defs/non_empty_strings" },
            "infrastructure": { "$ref": "#/$defs/non_empty_strings" }
          }
        },
        "failure_point_inventory": {
          "type": "array",
          "minItems": 8,
          "items": {
            "type": "object",
            "required": ["failure_id", "layer", "failure_point", "reviewed", "evidence"],
            "additionalProperties": false,
            "properties": {
              "failure_id": { "type": "string", "pattern": "^FP-[0-9]{3}$" },
              "layer": { "type": "string", "enum": ["ui", "api", "data", "auth", "workflow", "infrastructure"] },
              "failure_point": { "type": "string", "minLength": 10 },
              "reviewed": { "type": "boolean", "const": true },
              "evidence": { "type": "string", "minLength": 15 }
            }
          }
        },
        "issues": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "object",
            "required": [
              "issue_id", "title", "severity", "layer", "symptom", "root_cause", "location",
              "failure_mechanism", "impact", "fix_implemented", "files_changed", "why_fix_is_correct",
              "enterprise_alignment", "validation_evidence", "status"
            ],
            "additionalProperties": false,
            "properties": {
              "issue_id": { "type": "string", "pattern": "^ISSUE-[0-9]{3}$" },
              "title": { "type": "string", "minLength": 5 },
              "severity": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
              "layer": { "type": "string", "enum": ["ui", "api", "data", "auth", "workflow", "infrastructure"] },
              "symptom": { "type": "string", "minLength": 10 },
              "root_cause": { "type": "string", "minLength": 20 },
              "location": { "$ref": "#/$defs/non_empty_strings" },
              "failure_mechanism": { "type": "string", "minLength": 20 },
              "impact": { "type": "string", "minLength": 15 },
              "fix_implemented": { "type": "string", "minLength": 20 },
              "files_changed": { "$ref": "#/$defs/non_empty_strings" },
              "why_fix_is_correct": { "type": "string", "minLength": 20 },
              "enterprise_alignment": {
                "type": "array",
                "minItems": 2,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "enum": [
                    "clean_architecture", "modular_structure", "strong_typing", "schema_alignment",
                    "defensive_programming", "explicit_validation", "proper_error_handling", "no_hardcoding",
                    "no_duplicate_logic", "maintainability", "secure_access_control", "regression_safe"
                  ]
                }
              },
              "validation_evidence": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 15 }
              },
              "status": { "type": "string", "enum": ["fixed", "partially_fixed", "unresolved"] }
            }
          }
        },
        "validation": {
          "type": "object",
          "required": ["ui_validation", "functional_validation", "api_validation", "data_validation", "auth_validation", "error_handling_validation"],
          "additionalProperties": false,
          "properties": {
            "ui_validation": { "$ref": "#/$defs/validation_block" },
            "functional_validation": { "$ref": "#/$defs/validation_block" },
            "api_validation": { "$ref": "#/$defs/validation_block" },
            "data_validation": { "$ref": "#/$defs/validation_block" },
            "auth_validation": { "$ref": "#/$defs/validation_block" },
            "error_handling_validation": { "$ref": "#/$defs/validation_block" }
          }
        },
        "console_and_server_cleanliness": {
          "type": "object",
          "required": ["console_errors_present", "network_errors_present", "server_exceptions_present", "silent_failures_present", "details"],
          "additionalProperties": false,
          "properties": {
            "console_errors_present": { "type": "boolean" },
            "network_errors_present": { "type": "boolean" },
            "server_exceptions_present": { "type": "boolean" },
            "silent_failures_present": { "type": "boolean" },
            "details": { "type": "string", "minLength": 10 }
          }
        },
        "downstream_impact_analysis": {
          "type": "object",
          "required": ["linked_pages_reviewed", "shared_components_reviewed", "shared_services_reviewed", "regression_risk", "regression_checks"],
          "additionalProperties": false,
          "properties": {
            "linked_pages_reviewed": { "$ref": "#/$defs/non_empty_strings" },
            "shared_components_reviewed": { "$ref": "#/$defs/non_empty_strings" },
            "shared_services_reviewed": { "$ref": "#/$defs/non_empty_strings" },
            "regression_risk": { "type": "string", "enum": ["none_identified", "low", "medium", "high"] },
            "regression_checks": { "type": "array", "minItems": 2, "items": { "type": "string", "minLength": 3 } }
          }
        },
        "enterprise_standard_confirmation": {
          "type": "object",
          "required": [
            "clean_architecture", "modular_structure", "strong_typing_or_schema_alignment", "defensive_programming",
            "explicit_validation", "proper_error_handling", "no_hardcoding", "no_duplicate_logic", "maintainability",
            "secure_access_control", "regression_safe", "notes"
          ],
          "additionalProperties": false,
          "properties": {
            "clean_architecture": { "type": "boolean" },
            "modular_structure": { "type": "boolean" },
            "strong_typing_or_schema_alignment": { "type": "boolean" },
            "defensive_programming": { "type": "boolean" },
            "explicit_validation": { "type": "boolean" },
            "proper_error_handling": { "type": "boolean" },
            "no_hardcoding": { "type": "boolean" },
            "no_duplicate_logic": { "type": "boolean" },
            "maintainability": { "type": "boolean" },
            "secure_access_control": { "type": "boolean" },
            "regression_safe": { "type": "boolean" },
            "notes": { "type": "string", "minLength": 15 }
          }
        },
        "final_status": {
          "type": "object",
          "required": ["disposition", "summary", "remaining_issues"],
          "additionalProperties": false,
          "properties": {
            "disposition": { "type": "string", "enum": ["complete", "partial", "failed"] },
            "summary": { "type": "string", "minLength": 20 },
            "remaining_issues": { "type": "array", "items": { "type": "string", "minLength": 5 } }
          }
        }
      }
    }
  },
  "$defs": {
    "non_empty_strings": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 }
    },
    "validation_block": {
      "type": "object",
      "required": ["reviewed", "passed", "checks"],
      "additionalProperties": false,
      "properties": {
        "reviewed": { "type": "boolean", "const": true },
        "passed": { "type": "boolean" },
        "checks": { "type": "array", "minItems": 2, "items": { "type": "string", "minLength": 10 } }
      }
    }
  }
}